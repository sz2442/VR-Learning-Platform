# VR Meta University - Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_USER=vrcourses_user
DB_PASSWORD=your_secure_password_here_change_me
DB_NAME=vrcourses_db
DB_PORT=5432

# JWT Configuration (Backend)
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-characters-long-change-me

# Service Ports
BACKEND_PORT=5272
FRONTEND_PORT=3000
ML_SERVICE_PORT=8000

# API URL for Frontend
VITE_API_URL=http://localhost:5272/api

# Environment
ASPNETCORE_ENVIRONMENT=Development
LOG_LEVEL=INFO
